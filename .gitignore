# ─── Claude Code (IDE tool config — not project code) ─────────────────────────
.claude/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
pip-wheel-metadata/
*.egg-info/
dist/
build/

# ─── Robot Framework Output ───────────────────────────────────────────────────
# Ignore everything inside results/ except the .gitkeep placeholder
results/**
!results/.gitkeep

# ─── Appium / Mobile ──────────────────────────────────────────────────────────
# App binaries (use Git LFS or download in CI — never commit directly)
*.apk
*.ipa
*.aab
*.app

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ─── Secrets / credentials (never commit these!) ─────────────────────────────
.env
.env.local
secrets.yaml
credentials.yaml

# ─── Node (Appium global install) ─────────────────────────────────────────────
node_modules/
npm-debug.log*

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
appium.log

# Keep .gitkeep placeholder files
!results/.gitkeep
!apps/.gitkeep
!app/android/.gitkeep
!app/ios/.gitkeep

# CI-generated capability files (written at runtime by GitHub Actions)
config/ci_*_resolved.yaml
